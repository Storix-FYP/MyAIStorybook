%% MyAIStorybook - Use Case Diagram
%% Note: Mermaid doesn't have native use case diagram support
%% This is represented as a flowchart with styled nodes

graph TB
    %% Actors
    Guest[👤 Guest User]
    AuthUser[👤 Authenticated User]
    Parent[👤 Parent/Educator]
    Child[👤 Child]
    
    %% External Systems
    LLM[🤖 Ollama LLM]
    SD[🎨 Stable Diffusion]
    STT[🎤 Whisper STT]
    TTS[🔊 Coqui TTS]
    
    %% System Boundary
    subgraph MyAIStorybook System
        %% Story Generation Use Cases
        subgraph Story Generation
            UC1[Generate Story from Prompt]
            UC2[Generate Story from Voice Input]
            UC4[Generate Story Images]
            UC5[Generate Audio Narration]
        end
        
        %% Interactive Features
        subgraph Interactive Features
            UC3[Interactive Story Chat]
            UC_Chat[Chat with Story Characters]
            UC_Workshop[Idea Workshop]
        end
        
        %% Export Features
        subgraph Export Features
            UC6[Export Story to PDF]
            UC7[Export Story to Audio]
            UC_View[View Generated Stories]
        end
        
        %% Authentication
        subgraph Authentication
            UC_Register[Register Account]
            UC_Login[Login]
            UC_Profile[Manage Profile]
        end
    end
    
    %% Relationships
    Parent -.->|is a| AuthUser
    Child -.->|is a| Guest
    
    Guest --> UC1
    Guest --> UC_Register
    Guest --> UC_Login
    
    AuthUser --> UC1
    AuthUser --> UC2
    AuthUser --> UC3
    AuthUser --> UC4
    AuthUser --> UC5
    AuthUser --> UC6
    AuthUser --> UC7
    AuthUser --> UC_Chat
    AuthUser --> UC_Workshop
    AuthUser --> UC_View
    AuthUser --> UC_Profile
    
    UC1 -.->|include| UC4
    UC2 -.->|include| UC1
    UC1 -.->|include| UC6
    UC5 -.->|extend| UC1
    UC7 -.->|extend| UC5
    
    UC1 --> LLM
    UC4 --> SD
    UC2 --> STT
    UC5 --> TTS
    UC_Chat --> LLM
    UC_Workshop --> LLM
    
    %% Styling
    classDef actor fill:#e1f5ff,stroke:#01579b,stroke-width:2px
    classDef usecase fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    classDef system fill:#f3e5f5,stroke:#4a148c,stroke-width:2px
    
    class Guest,AuthUser,Parent,Child actor
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC_Chat,UC_Workshop,UC_View,UC_Register,UC_Login,UC_Profile usecase
    class LLM,SD,STT,TTS system
