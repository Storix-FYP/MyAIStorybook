%% Class Diagram for MyAIStorybook - Complete FYP System
%% Shows all classes across all iterations with relationships

classDiagram
    %% Core Domain Classes
    class Story {
        +string title
        +string setting
        +List~string~ characters
        +List~Scene~ scenes
        +dict meta
        +string language
        +string age_group
        +string theme
    }
    
    class Scene {
        +int scene_number
        +string text
        +string image_description
        +string image_path
        +string audio_path
        +float duration
    }
    
    class Character {
        +string name
        +string description
        +string appearance
        +string personality
        +string role
    }
    
    %% Agent Classes (Current + Future)
    class PromptAgent {
        +string model
        +process_prompt(prompt) tuple
        +classify_prompt(prompt) string
        +enhance_prompt(prompt) string
        +detect_language(prompt) string
    }
    
    class WriterAgent {
        +string llm_model
        +int max_retries
        +int max_scenes
        +generate_story(prompt) tuple
        +generate_character_backstories() dict
        +create_dialogue() string
        -_ask_ollama(prompt) string
        -_build_system_prompt() string
    }
    
    class ReviewerAgent {
        +review_story(story) tuple
        +validate_content(story) bool
        +check_age_appropriateness(story) bool
        +validate_coherence(story) bool
    }
    
    class EditorAgent {
        +edit_story(story) tuple
        +export_pdf(story, filename) string
        +format_for_publication(story) dict
        +apply_style_guide(story) dict
    }
    
    class ImageAgent {
        +string model_path
        +string device
        +generate_image(prompt, filename) string
        +generate_character_consistency() string
        +upscale_image(image) Image
        +apply_style_transfer(image) Image
    }
    
    class TTSAgent {
        +string voice_model
        +generate_audio(text, voice) string
        +synthesize_speech(text) AudioFile
        +apply_voice_effects(audio) AudioFile
    }
    
    class STTAgent {
        +string model_path
        +transcribe_audio(audio_file) string
        +process_voice_input(audio) string
        +detect_speech_emotion(audio) string
    }
    
    class ChatbotAgent {
        +string model
        +process_chat_input(message) string
        +maintain_conversation_context() dict
        +generate_responses(context) string
    }
    
    class DirectorAgent {
        +PromptAgent prompt_agent
        +WriterAgent writer
        +ReviewerAgent reviewer
        +EditorAgent editor
        +create_story(user_prompt, generate_images) dict
        +orchestrate_pipeline() dict
        +handle_errors() string
    }
    
    class StoryAgent {
        +DirectorAgent director
        +int max_retries
        +generate_story(prompt, generate_images) tuple
        +handle_user_interaction() dict
    }
    
    class EvaluationAgent {
        +evaluate_story(story_path) dict
        +compute_metrics(story) dict
        +assess_quality(story) float
        +generate_feedback(story) string
    }
    
    %% UI Classes
    class FrontendApp {
        +string framework
        +handle_user_input() void
        +display_story(story) void
        +manage_theme() void
    }
    
    class LandingPage {
        +show_welcome() void
        +collect_user_preferences() dict
    }
    
    class StoryInput {
        +validate_input() bool
        +submit_prompt() void
        +show_loading() void
    }
    
    class StoryDisplay {
        +render_story(story) void
        +handle_navigation() void
        +play_audio() void
    }
    
    %% API Classes
    class FastAPIApp {
        +handle_requests() Response
        +serve_static_files() File
        +manage_cors() void
    }
    
    class APIEndpoints {
        +generate_story() Response
        +get_device_info() Response
        +serve_generated_files() File
    }
    
    %% Relationships
    Story "1" *-- "3..*" Scene : contains
    Story "1" *-- "1..*" Character : features
    Scene "1" *-- "0..1" Character : features
    
    DirectorAgent o-- PromptAgent : uses
    DirectorAgent o-- WriterAgent : uses
    DirectorAgent o-- ReviewerAgent : uses
    DirectorAgent o-- EditorAgent : uses
    DirectorAgent ..> ImageAgent : optionally uses
    DirectorAgent ..> TTSAgent : optionally uses
    DirectorAgent ..> STTAgent : optionally uses
    DirectorAgent ..> ChatbotAgent : optionally uses
    
    StoryAgent o-- DirectorAgent : delegates to
    EvaluationAgent ..> Story : analyzes
    
    FrontendApp o-- LandingPage : contains
    FrontendApp o-- StoryInput : contains
    FrontendApp o-- StoryDisplay : contains
    
    FastAPIApp o-- APIEndpoints : uses
    FastAPIApp o-- StoryAgent : uses

