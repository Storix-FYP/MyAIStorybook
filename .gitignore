# MyAIStorybook - Git Ignore Rules
# Only push: backend/, frontend/, start_all.bat, README.md, .gitignore

# ===========================================
# IGNORE EVERYTHING BY DEFAULT
# ===========================================
*

# ===========================================
# ALLOW SPECIFIC FILES AND DIRECTORIES
# ===========================================

# Main project files
!README.md
!start_all.bat
!.gitignore

# Backend directory (entire backend folder)
!backend/
!backend/**

# Frontend directory (entire frontend folder)  
!frontend/
!frontend/**

# ===========================================
# IGNORE SPECIFIC FILES WITHIN ALLOWED DIRECTORIES
# ===========================================

# Backend - Ignore virtual environment and cache
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/**/*.so
backend/**/.pytest_cache/

# Backend - Ignore generated files
backend/generated/
backend/**/generated/
backend/**/*.log
backend/**/.env
backend/**/.env.local
backend/**/.env.*.local

# Backend - Ignore model files (too large for git)
backend/**/*.safetensors
backend/**/*.bin
backend/**/*.pt
backend/**/*.pth
backend/**/models/
backend/**/pretrained/

# Frontend - Ignore node_modules and build files
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/

# Frontend - Ignore cache and logs
frontend/.cache/
frontend/.parcel-cache/
frontend/**/*.log
frontend/**/.env.local
frontend/**/.env.development.local
frontend/**/.env.test.local
frontend/**/.env.production.local

# Frontend - Ignore IDE files
frontend/.vscode/
frontend/.idea/
frontend/**/.DS_Store
frontend/**/Thumbs.db

# ===========================================
# IGNORE SYSTEM FILES
# ===========================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
*.log

# ===========================================
# IGNORE DOCUMENTATION AND DIAGRAMS (if not needed)
# ===========================================

# Uncomment these if you don't want to push documentation
# document/
# diagrams/
# memory-bank/

# ===========================================
# IGNORE LARGE FILES AND GENERATED CONTENT
# ===========================================

# Large model files
*.safetensors
*.bin
*.pt
*.pth
*.h5
*.pkl

# Generated content
generated/
output/
temp/
cache/

# ===========================================
# IGNORE SENSITIVE FILES
# ===========================================

# Environment files
.env
.env.local
.env.*.local
.env.production
.env.development

# API keys and secrets
secrets.json
config.json
credentials.json

# ===========================================
# IGNORE BACKUP FILES
# ===========================================

*.bak
*.backup
*.old
*.orig